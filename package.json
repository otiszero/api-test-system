{
  "name": "api-test-system",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:smoke": "vitest run generated/tests/01-smoke",
    "test:contract": "vitest run generated/tests/02-contract",
    "test:single": "vitest run generated/tests/03-single",
    "test:integration": "vitest run generated/tests/04-integration",
    "test:rbac": "vitest run generated/tests/05-rbac",
    "test:security": "vitest run generated/tests/06-security",
    "test:db": "vitest run generated/tests/07-db",
    "full-test": "bash scripts/full-test.sh",
    "typecheck": "tsc --noEmit",
    "extract-endpoints": "tsx scripts/extract-endpoints.ts",
    "view-report": "npx vite preview --outDir reports/html",
    "view-evidence": "open reports/detailed-evidence.html",
    "e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "e2e:headed": "npx playwright test --config=e2e/playwright.config.ts --headed",
    "e2e:debug": "npx playwright test --config=e2e/playwright.config.ts --debug",
    "e2e:trace": "npx playwright show-trace",
    "e2e:wallet": "npx playwright test --config=e2e/playwright-wallet.config.ts --headed",
    "e2e:wallet:debug": "npx playwright test --config=e2e/playwright-wallet.config.ts --headed --debug"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@cucumber/gherkin": "^39.0.0",
    "@cucumber/messages": "^32.2.0",
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.58.2",
    "@synthetixio/synpress": "^4.1.2",
    "@types/js-yaml": "^4.0.9",
    "@types/pg": "^8.18.0",
    "@vitest/ui": "^4.0.18",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "yaml": "^2.8.2"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "mysql2": "^3.18.2",
    "otpauth": "^9.5.0",
    "pg": "^8.20.0"
  }
}
