{
  "_comment": "Integration test scenarios - QC có thể customize và regenerate tests",
  "_usage": "Modify scenarios below, then run: /generate integration",

  "scenarios": [
    {
      "id": "S01",
      "name": "User views markets and favorites",
      "description": "User browses markets, views detail, toggles favorite",
      "requiresAuth": true,
      "steps": [
        { "action": "GET", "endpoint": "/markets", "expect": 200, "saveAs": "marketList" },
        { "action": "GET", "endpoint": "/markets/${marketList.data[0].id}", "expect": 200, "saveAs": "marketDetail" },
        { "action": "POST", "endpoint": "/markets/${marketDetail.data.id}/favorite", "expect": [200, 201], "auth": "user" },
        { "action": "GET", "endpoint": "/markets/favorites", "expect": 200, "auth": "user" }
      ]
    },
    {
      "id": "S02",
      "name": "User views orders and positions",
      "description": "User checks their orders, positions, and activity",
      "requiresAuth": true,
      "steps": [
        { "action": "GET", "endpoint": "/orders", "expect": 200, "auth": "user" },
        { "action": "GET", "endpoint": "/orders/position", "expect": 200, "auth": "user" },
        { "action": "GET", "endpoint": "/orders/position-claims", "expect": 200, "auth": "user" },
        { "action": "GET", "endpoint": "/orders/activity", "expect": 200, "auth": "user" }
      ]
    },
    {
      "id": "S03",
      "name": "User views trades",
      "description": "User views market trades and personal trade history",
      "requiresAuth": true,
      "steps": [
        { "action": "GET", "endpoint": "/trades/market-trade", "expect": 200 },
        { "action": "GET", "endpoint": "/trades", "expect": 200, "auth": "user" },
        { "action": "GET", "endpoint": "/trades/history", "expect": 200, "auth": "user" }
      ]
    },
    {
      "id": "S04",
      "name": "Comment lifecycle",
      "description": "User views comments, creates comment, likes comment",
      "requiresAuth": true,
      "steps": [
        { "action": "GET", "endpoint": "/markets", "expect": 200, "saveAs": "markets" },
        { "action": "GET", "endpoint": "/comments/market/${markets.data[0].id}", "expect": [200, 404], "saveAs": "comments" },
        { "action": "POST", "endpoint": "/comments", "body": { "marketId": "${markets.data[0].id}", "content": "Test comment ${timestamp}" }, "expect": [200, 201, 400, 422], "auth": "user" },
        { "action": "POST", "endpoint": "/comments/1/like", "expect": [200, 201, 404], "auth": "user" }
      ]
    },
    {
      "id": "S05",
      "name": "Orderbook and statistics",
      "description": "User views orderbook and ranking",
      "requiresAuth": false,
      "steps": [
        { "action": "GET", "endpoint": "/orderbook", "expect": 200 },
        { "action": "GET", "endpoint": "/statistic/rank", "expect": 200 }
      ]
    },
    {
      "id": "S06",
      "name": "User profile and assets",
      "description": "User views their profile and assets",
      "requiresAuth": true,
      "steps": [
        { "action": "GET", "endpoint": "/auth/me", "expect": 200, "auth": "user" },
        { "action": "GET", "endpoint": "/auth/asset", "expect": 200, "auth": "user" }
      ]
    },
    {
      "id": "S07",
      "name": "Proposed markets flow",
      "description": "User views and votes on proposed markets",
      "requiresAuth": true,
      "steps": [
        { "action": "GET", "endpoint": "/markets/proposed", "expect": 200, "auth": "user" },
        { "action": "GET", "endpoint": "/markets/proposed-detail/1", "expect": [200, 404, 500], "auth": "user" }
      ]
    },
    {
      "id": "S08",
      "name": "Guest vs authenticated access",
      "description": "Verify public endpoints work without auth, protected require auth",
      "requiresAuth": false,
      "steps": [
        { "action": "GET", "endpoint": "/markets", "expect": 200, "auth": null, "description": "Public: should succeed" },
        { "action": "GET", "endpoint": "/orderbook", "expect": 200, "auth": null, "description": "Public: should succeed" },
        { "action": "GET", "endpoint": "/orders", "expect": 401, "auth": null, "description": "Protected: should fail" },
        { "action": "POST", "endpoint": "/comments", "body": { "content": "test" }, "expect": 401, "auth": null, "description": "Protected: should fail" }
      ]
    }
  ],

  "variables": {
    "timestamp": "${Date.now()}",
    "randomId": "${Math.floor(Math.random() * 1000)}"
  },

  "settings": {
    "stopOnFailure": false,
    "timeout": 10000,
    "retryCount": 0
  }
}
